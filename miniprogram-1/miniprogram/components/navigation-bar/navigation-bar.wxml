<!-- pages/component/navigation-bar.wxml -->
<view class="weui-navigation-bar {{extClass}}">
  <view class="weui-navigation-bar__inner {{ios ? 'ios' : 'android'}}" style="color: {{color}}; background: {{background}}; padding-right: {{innerPaddingRight}}; {{safeAreaTop}}">

    <!-- 左侧按钮 -->
    <view class='weui-navigation-bar__left' style="{{leftWidth}}">
      <block wx:if="{{back}}">
        <view class="weui-navigation-bar__btn_goback_wrapper" bindtap="back" hover-class="weui-active" hover-stay-time="100">
          <view class="weui-navigation-bar__btn_goback"></view>
        </view>
      </block>

      <block wx:if="{{!back && homeButton}}">
        <view class="weui-navigation-bar__btn_home_wrapper" bindtap="home" hover-class="weui-active">
          <view class="weui-navigation-bar__btn_home"></view>
        </view>
      </block>

      <block wx:if="{{!back && !homeButton}}">
        <slot name="left"></slot>
      </block>
    </view>

    <!-- 中间标题 -->
    <view class="weui-navigation-bar__center">
      <view wx:if="{{loading}}" class="weui-navigation-bar__loading">
        <view class="weui-loading"></view>
      </view>
      <block wx:if="{{title}}">
        <text>{{title}}</text>
      </block>
      <block wx:else>
        <slot name="center"></slot>
      </block>
    </view>

    <!-- 右侧 -->
    <view class="weui-navigation-bar__right">
      <slot name="right"></slot>
    </view>

  </view>
</view>