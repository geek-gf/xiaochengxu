/* pages/verify/verify.wxss */
.container {
  min-height: 100vh;
  background: #f5f6f7;
}

.page-header {
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: flex-end;
  padding-bottom: 20rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  position: relative;
  min-height: 100rpx;
}

.back-btn {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
  position: absolute;
  left: 20rpx;
  bottom: 16rpx;
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.verified-banner {
  background: linear-gradient(135deg, #07c160, #3cd97a);
  margin: 30rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.verified-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 16rpx;
}

.verified-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.tip-card {
  background: #e6f7ff;
  margin: 30rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 6rpx solid #1677ff;
}

.tip-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 30rpx 24rpx 0;
  padding: 10rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.form-group {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.form-group-last {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.submit-btn {
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 40rpx 24rpx 60rpx;
  height: 96rpx;
  line-height: 96rpx;
}
