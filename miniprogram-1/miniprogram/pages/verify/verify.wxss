/* pages/verify/verify.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.container1 {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.home-btn {
  position: absolute;
  right: 24rpx;
  font-size: 26rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.form-area {
  padding: 20rpx 24rpx 60rpx;
}

.verified-banner {
  background: linear-gradient(135deg, #07c160, #3cd97a);
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.verified-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  margin-right: 16rpx;
}

.verified-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.tip-card {
  background: #e6f7ff;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 6rpx solid #1677ff;
  margin-bottom: 20rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 10rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.form-group {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.form-group-last {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}

.submit-btn {
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 40rpx 0 0;
  height: 96rpx;
  line-height: 96rpx;
}
