/* pages/postDetail/postDetail.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
  padding-bottom: 130rpx;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.post-card {
  margin: 120rpx 30rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.post-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  padding: 20rpx 30rpx 10rpx;
  font-weight: bold;
}

.comment-list {
  padding: 0 30rpx;
}

.comment-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.avatar-sm {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.comment-body {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.comment-nick {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.loading-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.comment-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}

.comment-input {
  flex: 1;
  height: 80rpx;
  background: #f5f6f7;
  border-radius: 40rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
  white-space: nowrap;
}
