/* pages/myQuestions/myQuestions.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.container1 {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  width: 100%;
  padding-left: 30rpx;
  padding-right: 30rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  overflow-y: hidden;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.consultant-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.consultant-label {
  font-size: 24rpx;
  color: #999;
}

.consultant-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1677ff;
}

.consultant-title {
  font-size: 24rpx;
  color: #888;
  margin-left: 4rpx;
}

.q-content {
  font-size: 30rpx;
  color: #222;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.answer-block {
  background: #f0f7ff;
  border-left: 6rpx solid #1677ff;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.answer-label {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: bold;
}

.answer-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.no-answer {
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 16rpx;
}

.q-time {
  font-size: 22rpx;
  color: #bbb;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.load-more {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}
