<view class="page">
  <!-- 顶部导航 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="title">专家问答</text>
    <view class="home-btn" bindtap="goSquare">广场</view>
  </view>

  <!-- 专家信息 -->
  <view class="profile-card" style="margin-top: {{contentPaddingTop}}px;" wx:if="{{consultant}}">
    <image class="avatar" src="{{consultant.avatar}}" mode="aspectFill"></image>
    <view class="expert-name">{{consultant.name}}</view>
    <view class="expert-title">{{consultant.title}}</view>
    <view class="expert-intro">{{consultant.intro}}</view>
  </view>

  <!-- 问题区标题 -->
  <view class="section-title">收到的问题 ({{questions.length}})</view>

  <!-- 问题列表 -->
  <view class="question-list">
    <view class="question-item" wx:for="{{questions}}" wx:key="_id">
      <!-- 提问者 -->
      <view class="asker-row">
        <image class="avatar-sm" src="{{item.askerAvatar}}" mode="aspectFill"></image>
        <view class="asker-body">
          <text class="asker-name">{{item.askerName}}</text>
          <text class="q-time">{{item.timeAgo}}</text>
        </view>
      </view>
      <view class="q-content">{{item.content}}</view>

      <!-- 已有回答 -->
      <view class="answer-block" wx:if="{{item.answer}}">
        <text class="answer-label">我的回答：</text>
        <text class="answer-text">{{item.answer}}</text>
      </view>

      <!-- 回答入口 -->
      <view class="reply-btn" bindtap="toggleAnswerInput" data-index="{{index}}">
        {{item.showAnswerInput ? '收起' : (item.answer ? '修改回答' : '回答此问题')}}
      </view>
      <view wx:if="{{item.showAnswerInput}}" class="answer-input-area">
        <textarea
          class="answer-textarea"
          placeholder="输入你的回答..."
          value="{{item.answerDraft}}"
          bindinput="onAnswerInput"
          data-index="{{index}}"
        />
        <view class="answer-submit-btn" bindtap="submitAnswer" data-index="{{index}}">提交回答</view>
      </view>
    </view>

    <view wx:if="{{questions.length === 0 && !loading}}" class="empty-tip">暂时没有人向你提问~</view>
    <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  </view>
</view>
