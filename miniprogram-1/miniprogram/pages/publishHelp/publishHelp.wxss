/* pages/publishHelp/publishHelp.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.container1 {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.home-btn {
  position: absolute;
  right: 24rpx;
  font-size: 26rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.form-area {
  padding: 20rpx 24rpx 60rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 0;
}

.form-group {
  margin-bottom: 36rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.input-box {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
  color: #333;
}

.textarea-wrap {
  width: 100%;
  border: 1rpx solid #e8e8e8;
  border-radius: 16rpx;
  background: #fafafa;
  box-sizing: border-box;
  overflow: hidden;
}

.textarea-box {
  width: 100%;
  min-height: 280rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  padding: 0 20rpx 16rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 40rpx 0 0;
  height: 96rpx;
  line-height: 96rpx;
}
