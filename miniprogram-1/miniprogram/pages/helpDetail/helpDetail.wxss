/* pages/helpDetail/helpDetail.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 120rpx 30rpx 40rpx;
}

.publisher-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.publisher-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.publisher-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.status-tag {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-ongoing {
  background: #e6f7ff;
  color: #1677ff;
}

.status-done {
  background: #f6ffed;
  color: #52c41a;
}

.help-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.help-desc {
  font-size: 30rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 40rpx;
  white-space: pre-wrap;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.btn-area {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 600;
}

.btn-accept {
  background: #1677ff;
  color: #fff;
}

.btn-reject {
  background: #f5f6f7;
  color: #666;
  border: 1rpx solid #ddd;
}

.btn-done {
  background: #07c160;
  color: #fff;
}

.btn-cancel {
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.loading-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}
