<view class="page">
  <!-- 顶部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="title">求助详情</text>
  </view>

  <view class="content" wx:if="{{item}}">
    <!-- 发布者信息 -->
    <view class="publisher-row">
      <image class="avatar" src="{{item.publisherAvatar}}" mode="aspectFill"></image>
      <view class="publisher-info">
        <text class="publisher-name">{{item.publisherName}}</text>
        <text class="time">{{item.timeAgo}}</text>
      </view>
      <view class="status-tag status-{{item.status}}">
        <text wx:if="{{item.status === 'pending'}}">待接受</text>
        <text wx:elif="{{item.status === 'ongoing'}}">进行中</text>
        <text wx:else>已完成</text>
      </view>
    </view>

    <!-- 标题 -->
    <view class="help-title">{{item.title}}</view>

    <!-- 详细描述 -->
    <view class="help-desc">{{item.description}}</view>

    <!-- 操作按钮 -->
    <view class="btn-area">
      <!-- 非发布者 & pending → 接下求助 -->
      <view
        wx:if="{{!isPublisher && item.status === 'pending'}}"
        class="btn btn-accept"
        bindtap="acceptHelp"
      >接下求助</view>

      <!-- 非发布者 & pending → 拒绝（不接受） -->
      <view
        wx:if="{{!isPublisher && item.status === 'pending'}}"
        class="btn btn-reject"
        bindtap="goBack"
      >不接受</view>

      <!-- 接受者 & ongoing → 标记完成 -->
      <view
        wx:if="{{item.status === 'ongoing' && item.acceptorId === currentOpenid}}"
        class="btn btn-done"
        bindtap="completeHelp"
      >标记完成</view>

      <!-- 发布者 & pending → 撤销求助 -->
      <view
        wx:if="{{isPublisher && item.status === 'pending'}}"
        class="btn btn-cancel"
        bindtap="cancelHelp"
      >撤销求助</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
</view>
