/* pages/profile/profile.wxss */
page {
  height: 100%;
  background: #f5f6f7;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 顶部 */
.header {
    position: fixed;   /* 🔥 关键 */
    top: 0;
    left: 0;
    width: 100%;
  
    height: 180rpx;
    background: linear-gradient(135deg, #1677ff, #69a1ff);
  
    display: flex;
    align-items: center;
    padding-left: 30rpx;
  
    z-index: 999;
}
.title {
    color:#fff;
    font-size:40rpx;
    font-weight:bold;
}
.head{
    height: 350rpx; 
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

/* 头像 */
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  margin-bottom: 20rpx;
}

/* 昵称行 */
.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-item-inline {
  display: flex;
  align-items: center;
  font-size: 30rpx;
}

/* 昵称 */
.nickname {
  color: #000000;
  font-size: 36rpx;
  font-weight: bold;
}

/* 已认证标签（头像旁） */
.verified-tag {
  background: #1677ff;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 菜单区域 */
.menu {
  margin-top: -40rpx; /* 👈 卡片浮起来效果 */
  padding: 20rpx 0;
}

/* 单项 */
.menu-item {
  background: #fff;
  border-radius: 20rpx;
  width: 100%;
  padding: 30rpx;
  margin-bottom: 20rpx;

  display: flex;
  justify-content: space-between;
  align-items: center;

  font-size: 30rpx;
}

/* 右侧区域 */
.menu-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 已认证标签（菜单内） */
.verified-label {
  background: #e6f7ff;
  color: #1677ff;
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 右箭头 */
.arrow {
  color: #999;
}