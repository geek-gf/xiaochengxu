<!--pages/profile/profile.wxml-->
<view class="container">
<view class="header" style="padding-top: {{statusBarHeight}}px;">
  <text class="title">机小智智友会</text>
</view>

<!-- 未登录时：显示登录区域 -->
<view wx:if="{{!userInfo.openid}}" class="login-section">
  <button class="login-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
    <image class="login-avatar" src="{{loginAvatarUrl}}" mode="aspectFill" />
  </button>
  <view class="login-nickname-wrap">
    <input
      class="login-nickname-input"
      type="nickname"
      placeholder="点击设置微信昵称"
      value="{{loginNickName}}"
      bindinput="onNickNameInput"
    />
  </view>
  <button class="login-btn" bindtap="handleLogin" loading="{{loginLoading}}">微信登录 / 注册</button>
  <text class="login-tip">登录后可使用个人信息认证及全部功能</text>
</view>

<!-- 已登录时：显示正常个人信息 -->
<view wx:else>
<!-- 顶部区域 -->
<view class="head">
    <image 
  class="avatar" 
  src="{{userInfo.avatarUrl}}" 
  bindtap="changeAvatar"
/>
<view class="name-row">
  <view class="menu-item-inline" bindtap="goEditName">
    <text class="nickname-label">昵称：</text>
    <text class="value">{{userInfo.nickName}}</text>
  </view>
  <view wx:if="{{userInfo.isExpert}}" class="expert-tag">专家</view>
  <view wx:elif="{{userInfo.isVerified}}" class="verified-tag">已认证</view>
</view>
</view>

<!-- 专家工作台（仅专家可见） -->
<view wx:if="{{userInfo.isExpert}}" class="expert-card" bindtap="goExpertQA">
  <view class="expert-card-left">
    <text class="expert-card-icon">🎓</text>
    <view class="expert-card-info">
      <text class="expert-card-title">专家工作台</text>
      <text class="expert-card-desc">管理并回答用户的提问</text>
    </view>
  </view>
  <text class="expert-card-arrow">›</text>
</view>

<!-- 功能列表 -->
<view class="menu">

  <view class="menu-item" bindtap="goAuth">
    <text>个人信息认证</text>
    <view class="menu-right">
      <text wx:if="{{userInfo.isVerified}}" class="verified-label">已认证</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="menu-item" bindtap="goMyPosts">
    <text>我的帖子</text>
    <text class="arrow">></text>
  </view>

  <view class="menu-item" bindtap="goHelp">
    <text>我的求助</text>
    <text class="arrow">></text>
  </view>

  <view class="menu-item" bindtap="goMyQuestions">
    <text>我的提问</text>
    <text class="arrow">></text>
  </view>

  <view wx:if="{{!userInfo.isExpert}}" class="menu-item" bindtap="goExpertQA">
    <text>专家问答</text>
    <text class="arrow">></text>
  </view>

</view>

</view><!-- end wx:else -->

</view>