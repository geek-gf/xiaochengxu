/* pages/help/help.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.container1 {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  width: 100%;
  padding-left: 30rpx;
  padding-right: 30rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
  overflow-y: hidden;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-row {
  display: flex;
  align-items: center;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.publisher-name {
  font-size: 26rpx;
  color: #555;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-ongoing {
  background: #e6f7ff;
  color: #1677ff;
}

.status-done {
  background: #f6ffed;
  color: #52c41a;
}

.help-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 12rpx;
}

.help-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.help-time {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 16rpx;
}

.btn-row {
  display: flex;
  justify-content: flex-end;
}

.btn {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.btn-accept {
  background: #1677ff;
  color: #fff;
}

.btn-done {
  background: #07c160;
  color: #fff;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.load-more {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}

.publish-btn {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #3cd97a);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  border: 2rpx solid #f2f2f2;
  z-index: 100;
}
