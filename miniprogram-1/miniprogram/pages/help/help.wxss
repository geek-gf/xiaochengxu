/* pages/help/help.wxss */
.page {
    display: flex;
    height:auto;
    background: #f5f5f5;
  }
  
  /* 顶部 */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 120rpx;
    background: #1677ff;
    color: #fff;
    text-align: center;
    line-height: 120rpx;
    font-size: 32rpx;
    z-index: 999;
  }
  
  /* 内容区域 */
  .content {
    height: auto;
    overflow: visible;
    margin-top: 120rpx; /* 给 header 腾位置 */
    padding: 20rpx;
  }
  
  /* 每一条 */
  .item {
    background: #fff;
    padding: 30rpx;
    margin-bottom: 20rpx;
    border-radius: 12rpx;
  }