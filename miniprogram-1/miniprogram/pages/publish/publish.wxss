/* pages/publish/publish.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.container1 {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.home-btn {
  position: absolute;
  right: 24rpx;
  font-size: 26rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 20rpx 30rpx 30rpx;
}

.input-box {
  width: 100%;
  height: 300rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 40rpx;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
}