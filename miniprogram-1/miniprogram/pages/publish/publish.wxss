/* pages/publish/publish.wxss */
.container {
    padding: 0 30rpx 30rpx;
  }

.page-header {
  display: flex;
  align-items: center;
  height: 100rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.back-btn {
  font-size: 60rpx;
  color: #333;
  line-height: 1;
  padding: 0 10rpx;
  position: absolute;
  left: 0;
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
  
  .input-box {
    width: 100%;
    height: 300rpx;
    border: 1px solid #ddd;
    border-radius: 20rpx;
    padding: 20rpx;
  }
  
  .submit-btn {
    margin-top: 40rpx;
    background: #07c160;
    color: #fff;
    border-radius: 40rpx;
  }