<!--pages/publish/publish.wxml-->
<view class="container">

<view class="page-header" style="padding-top: {{statusBarHeight}}px;">
  <view class="back-btn" bindtap="goBack">‹</view>
  <text class="page-title">发帖</text>
</view>

<textarea 
  placeholder="说点什么吧..."
  bindinput="onInput"
  class="input-box"
/>

<button class="submit-btn" bindtap="submitPost">
  发布
</button>

</view>