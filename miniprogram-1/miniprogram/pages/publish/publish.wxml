<!--pages/publish/publish.wxml-->
<view class="page">
  <view class="container1">
    <view class="header" style="padding-top: {{statusBarHeight}}px;">
      <view class="back-btn" bindtap="goBack">‹</view>
      <text class="title">发帖</text>
      <view class="home-btn" bindtap="goSquare">广场</view>
    </view>

    <view class="content" style="margin-top: {{contentPaddingTop}}px;">
      <textarea
        placeholder="说点什么吧..."
        bindinput="onInput"
        class="input-box"
      />
      <button class="submit-btn" bindtap="submitPost">发布</button>
    </view>
  </view>
</view>