/* pages/editName/editName.wxss */
.container {
    padding: 0 40rpx 40rpx;
  }

.page-header {
  display: flex;
  align-items: center;
  height: 100rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.back-btn {
  font-size: 60rpx;
  color: #333;
  line-height: 1;
  padding: 0 10rpx;
  position: absolute;
  left: -10rpx;
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
  
  .input {
    background: #f5f5f5;
    border-radius: 16rpx;
    padding: 25rpx;
    font-size: 30rpx;
  }
  
  .btn {
    margin-top: 60rpx;
    background: #1677ff;
    color: #fff;
    border-radius: 20rpx;
  }