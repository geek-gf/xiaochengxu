<!--pages/editName/editName.wxml-->
<view class="page">
  <view class="container1">
    <view class="header" style="padding-top: {{statusBarHeight}}px;">
      <view class="back-btn" bindtap="goBack">‹</view>
      <text class="title">修改昵称</text>
      <view class="home-btn" bindtap="goSquare">广场</view>
    </view>

    <view class="content" style="margin-top: {{contentPaddingTop}}px;">
      <input
        class="input"
        placeholder="请输入昵称（2-10个字符）"
        value="{{nickName}}"
        bindinput="onInput"
      />
      <button class="btn" bindtap="save">保存</button>
    </view>
  </view>
</view>