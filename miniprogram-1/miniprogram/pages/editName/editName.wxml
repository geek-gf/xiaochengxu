<!--pages/editName/editName.wxml-->
<view class="container">

<view class="page-header">
  <view class="back-btn" bindtap="goBack">‹</view>
  <text class="page-title">修改昵称</text>
</view>

<input 
  class="input"
  placeholder="请输入昵称（2-10个字符）"
  value="{{nickName}}"
  bindinput="onInput"
/>

<button class="btn" bindtap="save">保存</button>

</view>