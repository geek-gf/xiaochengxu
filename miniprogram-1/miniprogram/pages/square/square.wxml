<view class="page">
<view class="container1">
<!-- 顶部 -->
<view class="header" style="padding-top: {{statusBarHeight}}px;">
  <text class="title">机小智智友会</text>
</view>

<!-- 列表内容（不要 scroll-view！） -->
<view class="content">
  <block wx:for="{{postList}}" wx:key="_id">
    
    <view class="card" bindtap="goPostDetail" data-id="{{item._id}}">

      <!-- 用户信息 -->
      <view class="user-row">
        <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>

        <view class="user-info">
          <text class="nickname">{{item.nickName}}</text>
          <text class="time">{{item.timeAgo}}</text>
        </view>
      </view>

      <!-- 内容 -->
      <view class="post-content">
        {{item.content}}
      </view>

    </view>

  </block>

  <!-- 加载状态 -->
  <view class="load-more">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{noMore}}">—— 没有更多了 ——</text>
  </view>

</view>
<!-- 悬浮发布按钮 -->
<view class="publish-btn" bindtap="goPublish">
  +
</view>
</view>
</view>