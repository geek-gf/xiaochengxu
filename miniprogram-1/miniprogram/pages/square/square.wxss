/* 整体布局 */
.page {
    min-height: 100vh;
}
.container1 {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }
  
  /* 顶部渐变栏 */
.header {
    position: fixed;  
    top: 0;
    left: 0;
    width: 100%;
  
    height: 140rpx;
    background: linear-gradient(135deg, #1677ff, #69a1ff);
  
    display: flex;
    align-items: center;
    padding-left: 30rpx;
  
    z-index: 999;
  }
.title {
     color:#fff;
     font-size:40rpx;
     font-weight:bold;
}
/* 内容区域 */
.content {
    width: 100%;
    padding-left: 30rpx;
    padding-right: 30rpx;
    padding-bottom: 40rpx;
    box-sizing: border-box;
    overflow-y: hidden;
  }
/* 卡片 */
.card {
    background:#fff;
     border-radius:24rpx;
     padding:25rpx;
     width: 100%;
     margin-bottom: 20rpx;
     box-shadow:0 10rpx 25rpx rgba(0,0,0,0.06);
}
 /* 用户行 */
 .user-row {
     display:flex;
     align-items:center;
     margin-bottom:15rpx;
}
 /* 头像 */
.avatar {
     width:80rpx;
     height:80rpx;
     border-radius:50%;
     margin-right:20rpx;
}
/* 用户信息 */
.user-info {
     display:flex;
     flex-direction:column;
}
/* 昵称 */
.nickname {
     font-size:30rpx;
     font-weight:600;
}
/* 时间 */
.time {
     font-size:22rpx;
     color:#999;
     margin-top:6rpx;
}
/* 内容 */
.post-content {
     font-size:30rpx;
     color:#333;
     line-height:1.7;
     white-space:pre-wrap;
 }
/* 操作行（点赞/评论） */
.action-row {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 32rpx;
}

.action-count {
  font-size: 26rpx;
  color: #999;
}

.action-item.liked .action-count {
  color: #ff4d4f;
}

/* 悬浮按钮 */
.publish-btn {
     position:fixed;
     right:40rpx;
     bottom:160rpx;
     min-width:110rpx;
     height:110rpx;
     border-radius:55rpx;
     background:linear-gradient(135deg, #1677ff, #69a1ff);
     color:#fff;
     display:flex;
     flex-direction: column;
     align-items:center;
     justify-content:center;
     box-shadow: 0 8rpx 24rpx rgba(22,119,255,0.45);
     padding: 0 24rpx;
     gap: 4rpx;
}
.publish-btn-icon {
  font-size: 36rpx;
  line-height: 1;
}
.publish-btn-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}
.load-more {
    text-align: center;
    color: #000;        /* 文字颜色（可以改深一点） */
    font-size: 32rpx;   /* 字体变大 */
    font-weight: bold;  /* 加粗 */
    padding: 30rpx 0;
    background: none;   /* 确保没有背景（保险写法） */
}