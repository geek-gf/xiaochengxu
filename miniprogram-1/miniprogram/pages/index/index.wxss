/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 32rpx;
}

.app-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 80rpx;
}

.wechat-login-btn {
  width: 80%;
  background-color: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
}
