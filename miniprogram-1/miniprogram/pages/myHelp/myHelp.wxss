/* pages/myHelp/myHelp.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.container1 {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
  padding: 0 10rpx;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  width: 100%;
  padding-left: 30rpx;
  padding-right: 30rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  overflow-y: hidden;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.help-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  flex: 1;
  margin-right: 20rpx;
}

.status-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  white-space: nowrap;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-ongoing {
  background: #e6f7ff;
  color: #1677ff;
}

.status-done {
  background: #f6ffed;
  color: #52c41a;
}

.help-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.help-time {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 12rpx;
}

.btn-row {
  display: flex;
  justify-content: flex-end;
}

.btn {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.btn-end {
  background: #ff4d4f;
  color: #fff;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.load-more {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}
