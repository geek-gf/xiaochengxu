<view class="page">
  <view class="container1">
    <view class="header" style="padding-top: {{statusBarHeight}}px;">
      <view class="back-btn" bindtap="goBack">‹</view>
      <text class="title">我的求助</text>
    </view>

    <scroll-view
      class="content"
      scroll-y="{{true}}"
      lower-threshold="120"
      refresher-enabled="true"
      refresher-triggered="{{refresherTriggered}}"
      bindrefresherrefresh="onRefresherRefresh"
      style="margin-top: {{contentPaddingTop}}px; height: {{scrollHeight}}px;"
    >
      <view wx:if="{{list.length === 0 && !loading}}" class="empty-tip">
        还没有发布过求助~
      </view>

      <block wx:for="{{list}}" wx:key="_id">
        <view class="card" bindtap="goDetail" data-id="{{item._id}}">
          <view class="card-top">
            <view class="help-title">{{item.title}}</view>
            <view class="status-tag status-{{item.status}}">
              <text wx:if="{{item.status === 'pending'}}">待接受</text>
              <text wx:elif="{{item.status === 'ongoing'}}">进行中</text>
              <text wx:else>已完成</text>
            </view>
          </view>
          <view class="help-desc">{{item.description}}</view>
          <view class="help-time">{{item.timeAgo}}</view>
          <!-- 结束求助按钮（仅发布者可见，且状态不为已完成） -->
          <view
            wx:if="{{item.status !== 'done' && item.publisherId === currentOpenid}}"
            class="btn-row"
          >
            <view
              class="btn btn-end"
              catchtap="endHelp"
              data-id="{{item._id}}"
            >结束求助</view>
          </view>
        </view>
      </block>

      <view class="load-more">
        <text wx:if="{{loading}}">加载中...</text>
      </view>
    </scroll-view>
  </view>
</view>
