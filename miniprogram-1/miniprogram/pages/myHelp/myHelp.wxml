<view class="page">
  <view class="header">
    <text class="title">我的求助</text>
  </view>

  <view class="content">
    <view wx:if="{{list.length === 0 && !loading}}" class="empty-tip">
      还没有发布过求助~
    </view>

    <block wx:for="{{list}}" wx:key="_id">
      <view class="card">
        <view class="card-top">
          <view class="help-title">{{item.title}}</view>
          <view class="status-tag status-{{item.status}}">
            <text wx:if="{{item.status === 'pending'}}">待接受</text>
            <text wx:elif="{{item.status === 'ongoing'}}">进行中</text>
            <text wx:else>已完成</text>
          </view>
        </view>
        <view class="help-desc">{{item.description}}</view>
        <view class="help-time">{{item.timeAgo}}</view>
      </view>
    </block>

    <view class="load-more">
      <text wx:if="{{loading}}">加载中...</text>
    </view>
  </view>
</view>
