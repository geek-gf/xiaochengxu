/* pages/myPosts/myPosts.wxss */
.page {
  min-height: 100vh;
  background: #f5f6f7;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #1677ff, #69a1ff);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 120rpx 30rpx 30rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: 600;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.post-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  white-space: pre-wrap;
}

.empty-tip {
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.load-more {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 20rpx 0;
}
