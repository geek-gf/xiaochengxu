<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="title">我的帖子</text>
  </view>

  <view class="content">
    <block wx:for="{{postList}}" wx:key="_id">
      <view class="card" bindtap="goPostDetail" data-id="{{item._id}}">
        <view class="user-row">
          <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view class="user-info">
            <text class="nickname">{{item.nickName}}</text>
            <text class="time">{{item.timeAgo}}</text>
          </view>
        </view>
        <view class="post-content">{{item.content}}</view>
      </view>
    </block>

    <view wx:if="{{postList.length === 0 && !loading}}" class="empty-tip">
      还没有发过帖子，快去发一篇吧~
    </view>

    <view class="load-more">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:elif="{{noMore && postList.length > 0}}">—— 没有更多了 ——</text>
    </view>
  </view>
</view>
